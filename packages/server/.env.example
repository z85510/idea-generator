OPENROUTER_API_KEY=your-openrouter-key
API_SECRET_KEY=your-frontend-secret
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TEMPERATURE=0.9
# Or use Claude Haiku 4.5: anthropic/claude-haiku-4.5
IDEAS_DB_PATH=ideas.db
OUTPUT_NUMBER=5
# Optional: cache TTL in days. Same prompt reuses cache only if created_at is within this window (e.g. 7 = refresh weekly).
# IDEAS_CACHE_TTL_DAYS=7
# Allowed browser origins (comma-separated). Only these can call the API from a browser; empty = no restriction.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001